# --- 見た目の設定 ---
# 背景を少し透かしてオシャレに (0.8〜0.9がおすすめ)
background_opacity 0.9
background_blur 1


# --- 144Hzモニターへの最適化 ---
# 描画遅延を最小限にする (144fpsに合わせる)
#repaint_delay 7
#input_delay 2
#sync_to_monitor yes

# --- 操作性の向上 ---
# スクロールバックの行数を増やす（過去のログをたくさん保持）
#scrollback_lines 5000

# ターミナルのベル音を消す（集中力を削がない）
enable_audio_bell no

#フォントの設定
font_family JetBrainsMono Nerd Font
font_size 14.0
bold_font        auto
italic_font      auto
bold_italic_font auto

# 日本語フォントをフォールバックに指定
symbol_map U+4E00-U+9FFF,U+3041-U+3096,U+30A1-U+30FC Noto Sans CJK JP

# BEGIN_KITTY_THEME
# Tokyo Night
include current-theme.conf
# END_KITTY_THEME
